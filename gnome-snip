#!/usr/bin/env python3
"""gnome-snip — GNOME Wayland 截图 + 贴图 + 标注工具"""
import signal
import sys
import os

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from gnome_snip.app import App


def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    App().run()


if __name__ == '__main__':
    main()
